{
  "name": "thehive-cortex-mcp",
  "version": "1.3.1",
  "description": "Cortex observable-analysis control CLI with an MCP adapter",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cortexctrl": "./dist/cli.js",
    "cortexctl": "./dist/cli.js",
    "cortex-mcp": "./dist/mcp-bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/mcp-bin.ts",
    "start": "node dist/mcp-bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lidless-labs/cortex-mcp.git"
  },
  "homepage": "https://github.com/lidless-labs/cortex-mcp#readme",
  "bugs": {
    "url": "https://github.com/lidless-labs/cortex-mcp/issues"
  },
  "keywords": [
    "mcp",
    "cortex",
    "thehive",
    "soc",
    "security",
    "observable-analysis",
    "incident-response"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^6.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "npm@10.9.7"
}
